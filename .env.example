# MSSQL Database Configuration
# These values are used by Docker Compose for the MSSQL service
# Copy this file to .env and update with your values (or use defaults for development)
# Note: The .env file is gitignored and will not be committed

# MSSQL SA Password - Change this in production!
# Default: YourStrong@Passw0rd
MSSQL_SA_PASSWORD=YourStrong@Passw0rd

# JWT secret key for token signing. Must be at least 32 characters.
JWTSETTINGS__SECRETKEY=OverrideInProductionUseEnvVarJWTSETTINGS__SECRETKEY_please!

# Secret key for HMAC-SHA256 hashing of high-level PII like
# Phone, SnapId, TanfId, Ssn. Must be at least 32 characters.
IDENTIFIERHASHER__SECRETKEY=OverrideInProductionUseEnvVarIDENTIFIERHASHER__SECRETKEY_please!

# Database Configuration
# Defaults shown below - override as needed
MSSQL_DATABASE=SebtPortal
MSSQL_USER=sa
MSSQL_SERVER=mssql
MSSQL_PORT=1433

# OIDC Step-up
# Next.js reads these from .env.local; copy from src/SEBT.Portal.Web/.env.example
# OIDC_STEP_UP_DISCOVERY_ENDPOINT=https://auth.pingone.com/YOUR_ENV_ID/as/.well-known/openid-configuration
# OIDC_STEP_UP_CLIENT_ID=your_step_up_client_id
# OIDC_STEP_UP_CLIENT_SECRET=your_step_up_client_secret
# OIDC_STEP_UP_REDIRECT_URI=http://localhost:3000/callback
