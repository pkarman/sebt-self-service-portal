      "ClientId": "YOUR_OIDC_STEP_UP_CLIENT_ID",
      "RedirectUri": null
    }
  },
  "DevelopmentPhoneOverride": {
    "Phone": null
  },
  "AddressValidationPolicy": {
    "AllowGeneralDelivery": true
  },
  "Smarty": {
    "Enabled": false,
    "AuthId": "",
    "AuthToken": ""
  },
  "Socure": {
    "Enabled": false
  },
  "IdProofingRequirements": {
    "address+view": "IAL1plus",
    "email+view": "IAL1plus",
    "phone+view": "IAL1"
  }
