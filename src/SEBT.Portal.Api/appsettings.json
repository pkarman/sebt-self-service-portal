{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "EmailOtpSenderServiceSettings": {
    "SenderEmail": "sender1@example.com",
    "Subject": "Your One-Time Password (OTP)",
    "HtmlPreOtp": "<p>Your One-Time Password (OTP) is:</p><h2>",
    "HtmlPostOtp": "</h2><p>This OTP is valid for 10 minutes.</p>"
  },
  "SmtpClientSettings": {
    "SmtpServer": "localhost",
    "SmtpPort": 1025,
    "EnableSsl": false
  }
}