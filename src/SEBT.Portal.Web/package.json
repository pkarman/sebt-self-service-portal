{
  "name": "@sebt/web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "tokens": "node design/scripts/generate-tokens.js",
    "tokens:sass": "node design/scripts/generate-sass-tokens.js",
    "tokens:fonts": "node design/scripts/generate-fonts.js",
    "tokens:all": "node design/scripts/generate-all-tokens.js",
    "copy:generate": "node content/scripts/generate-locales.js",
    "copy:validate": "node content/scripts/generate-locales.js --validate",
    "copy-uswds-assets": "sh design/scripts/copy-uswds-assets.sh",
    "postinstall": "pnpm copy-uswds-assets",
    "predev": "node design/scripts/state-banner.js && pnpm --silent tokens && pnpm --silent tokens:sass && pnpm --silent tokens:fonts && pnpm --silent copy:generate",
    "dev": "next dev --turbopack",
    "prebuild": "node design/scripts/state-banner.js && pnpm --silent tokens && pnpm --silent tokens:sass && pnpm --silent tokens:fonts && pnpm --silent copy:generate",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "pretest": "pnpm --silent copy:generate",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:a11y": "pa11y-ci",
    "lighthouse": "lhci autorun",
    "analyze": "ANALYZE=true pnpm build",
    "size": "size-limit",
    "knip": "knip",
    "knip:production": "knip --production"
  },
  "dependencies": {
    "@next/third-parties": "^16.1.4",
    "@t3-oss/env-nextjs": "^0.13.8",
    "@tanstack/react-query": "^5.90.12",
    "@uswds/uswds": "^3.13.0",
    "i18next": "^25.7.3",
    "next": "16.0.8",
    "react": "19.2.1",
    "react-dom": "19.2.1",
    "react-i18next": "^16.5.0",
    "usehooks-ts": "^3.1.1",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@axe-core/react": "^4.11.0",
    "@lhci/cli": "^0.15.1",
    "@next/bundle-analyzer": "^16.0.8",
    "@playwright/test": "^1.57.0",
    "@size-limit/file": "^12.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.0.15",
    "axe-core": "^4.11.0",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.0.8",
    "eslint-plugin-security": "^3.0.1",
    "jsdom": "^27.3.0",
    "msw": "^2.12.4",
    "pa11y-ci": "^4.0.1",
    "prettier": "^3.7.4",
    "prettier-plugin-organize-imports": "^4.3.0",
    "sass": "^1.95.0",
    "sass-embedded": "^1.96.0",
    "sass-loader": "^16.0.6",
    "size-limit": "^12.0.0",
    "typescript": "^5",
    "vitest": "^4.0.15"
  }
}
