# SEBT Portal Environment Configuration
# Copy to .env.local

# =============================================================================
# Build-time configuration
# =============================================================================

# State identifier - determines design tokens, theme, and locale namespace
# Exposed to browser as NEXT_PUBLIC_STATE via next.config.ts
# Valid values: dc | co
STATE=dc

# =============================================================================
# Server-side (not exposed to browser)
# =============================================================================

# Backend API URL - requests are proxied through Next.js API routes
BACKEND_URL=http://localhost:5280

# Origin of the enrollment checker static site (e.g. https://dev.co.sebt-enrollment.codeforamerica.app).
# When set, the portal returns CORS headers on /api/enrollment/* responses so the SSG-deployed
# enrollment checker can call the portal API cross-origin. Leave unset if the checker is not in use
# or is served same-origin. The `pnpm dev:co` script sets this automatically for local development.
# ENROLLMENT_CHECKER_ORIGIN=http://localhost:3001

# OIDC (state IdP sign-in; used when STATE is set to a state that uses OIDC).
# Must match the API's Oidc:* values — in particular OIDC_COMPLETE_LOGIN_SIGNING_KEY
# must equal Oidc:CompleteLoginSigningKey in appsettings.
OIDC_DISCOVERY_ENDPOINT=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=http://localhost:3000/callback
# OIDC_LANGUAGE_PARAM=en
OIDC_COMPLETE_LOGIN_SIGNING_KEY=

# =============================================================================
# Client-side (exposed to browser)
# =============================================================================

# Google Analytics Measurement ID (optional)
# Format: G-XXXXXXXXXX
# Leave empty to disable analytics
NEXT_PUBLIC_GA_ID=

# Amplitude Browser SDK API key (optional; state-specific)
# Obtain from the Amplitude project for the target state/environment.
# Leave empty to disable Amplitude.
NEXT_PUBLIC_AMPLITUDE_API_KEY=

# Mixpanel project token (optional; state-specific)
# Obtain from the Mixpanel project for the target state/environment.
# Leave empty to disable Mixpanel.
NEXT_PUBLIC_MIXPANEL_TOKEN=

# Development only: repeat OIDC step-up on each IalGuard load even when JWT already has IAL1+.
# NEXT_PUBLIC_DEBUG_REPEAT_OIDC_STEP_UP=false

# Socure SDK keys — obtain from Socure RiskOS dashboard > Developer Workbench > SDK Keys
# Sandbox and production keys are different. Both keys below use the same value (single SDK key in Socure).
NEXT_PUBLIC_SOCURE_SDK_KEY=
NEXT_PUBLIC_SOCURE_DI_SDK_KEY=

# Socure adapter mode.
# - true  = use in-browser mock adapter; no Socure credentials or network calls required.
#           The DocV flow renders a simulated capture UI that can complete or fail on demand.
#           Useful for UI review, running the app without sandbox access, and unit/E2E tests.
# - false = use the real Socure Web SDK. Requires valid NEXT_PUBLIC_SOCURE_SDK_KEY,
#           network access to websdk.socure.com and verify-v2.socure.com, and a backend
#           configured to mint real docv transaction tokens (see Socure:* in appsettings).
# Leave blank to default to the real adapter (equivalent to false).
NEXT_PUBLIC_MOCK_SOCURE=

# Smarty US Autocomplete Pro embeddable key.
# Enables type-ahead address suggestions in the change-address form.
# Obtain from Smarty dashboard > API Keys > Embedded Key.
# Domain-restricted in Smarty dashboard — safe for client-side use.
# Leave empty to disable autocomplete (users type addresses manually).
NEXT_PUBLIC_SMARTY_EMBEDDED_KEY=
