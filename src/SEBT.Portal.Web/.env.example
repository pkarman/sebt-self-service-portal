# SEBT Portal Environment Configuration
# Copy to .env.local

# =============================================================================
# Build-time configuration
# =============================================================================

# State identifier - determines design tokens, theme, and locale namespace
# Exposed to browser as NEXT_PUBLIC_STATE via next.config.ts
# Valid values: dc | co
STATE=dc

# =============================================================================
# Server-side (not exposed to browser)
# =============================================================================

# Backend API URL - requests are proxied through Next.js API routes
BACKEND_URL=http://localhost:5280

# OIDC (state IdP sign-in; used when STATE is set to a state that uses OIDC)
# Same signing key must be set in API (Oidc:CompleteLoginSigningKey)
# PingOne: register every redirect URI you use (exact match). The app sends
# {browser origin}/callback (e.g. http://localhost:3000/callback and
# http://localhost:3001/callback if Next uses an alternate port).
OIDC_DISCOVERY_ENDPOINT=https://auth.pingone.com/YOUR_ENV_ID/as/.well-known/openid-configuration
OIDC_CLIENT_ID=your_client_id
OIDC_CLIENT_SECRET=your_client_secret
OIDC_REDIRECT_URI=http://localhost:3000/callback
OIDC_LANGUAGE_PARAM=en
OIDC_COMPLETE_LOGIN_SIGNING_KEY=at_least_32_characters_shared_with_api

# OIDC Step-up (second client in PingOne for IAL1+ verification when the user needs higher assurance)
# OIDC_STEP_UP_DISCOVERY_ENDPOINT=https://auth.pingone.com/YOUR_ENV_ID/as/.well-known/openid-configuration
# OIDC_STEP_UP_CLIENT_ID=your_step_up_client_id
# OIDC_STEP_UP_CLIENT_SECRET=your_step_up_client_secret
# OIDC_STEP_UP_REDIRECT_URI=http://localhost:3000/callback

# =============================================================================
# Client-side (exposed to browser)
# =============================================================================

# Google Analytics Measurement ID (optional)
# Format: G-XXXXXXXXXX
# Leave empty to disable analytics
NEXT_PUBLIC_GA_ID=

# Development only: repeat OIDC step-up on each IalGuard load even when JWT already has IAL1+.
# NEXT_PUBLIC_DEBUG_REPEAT_OIDC_STEP_UP=false
# OIDC: require step-up when portal JWT id_proofing_completed_at is older than this many years (default 5).
# NEXT_PUBLIC_CO_ID_PROOFING_MAX_AGE_YEARS=5

# Socure DocV SDK key (required for document verification)
# Obtain from Socure dashboard — use sandbox key for development
NEXT_PUBLIC_SOCURE_SDK_KEY=
