# SEBT Portal Environment Configuration
# Copy to .env.local

# =============================================================================
# Build-time configuration
# =============================================================================

# State identifier - determines design tokens, theme, and locale namespace
# Exposed to browser as NEXT_PUBLIC_STATE via next.config.ts
# Valid values: dc | co
STATE=dc

# =============================================================================
# Server-side (not exposed to browser)
# =============================================================================

# Backend API URL - requests are proxied through Next.js API routes
BACKEND_URL=http://localhost:5280

# OIDC (state IdP sign-in; used when STATE is set to a state that uses OIDC)
# Same signing key must be set in API (Oidc:CompleteLoginSigningKey)
# OIDC_DISCOVERY_ENDPOINT=https://auth.pingone.com/YOUR_ENV_ID/as/.well-known/openid-configuration
# OIDC_CLIENT_ID=your_client_id
# OIDC_CLIENT_SECRET=your_client_secret
# OIDC_REDIRECT_URI=http://localhost:3000/callback
# OIDC_LANGUAGE_PARAM=en
# OIDC_COMPLETE_LOGIN_SIGNING_KEY=at_least_32_characters_shared_with_api

# =============================================================================
# Client-side (exposed to browser)
# =============================================================================

# Google Analytics Measurement ID (optional)
# Format: G-XXXXXXXXXX
# Leave empty to disable analytics
NEXT_PUBLIC_GA_ID=
